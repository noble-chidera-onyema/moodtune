# MoodTune environment variables
   # Copy this file to .env and fill in your own keys
   # Do NOT commit your real .env file to GitHub

   # Groq Cloud API (get from https://console.groq.com)
   GROQ_API_KEY=your_groq_api_key_here

   # Spotify Web API (get from https://developer.spotify.com/dashboard)
   SPOTIFY_CLIENT_ID=your_spotify_client_id_here
   SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

   # Optional — researcher contact email (for app display)
   RESEARCHER_EMAIL=researcher@example.com
